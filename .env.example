# ─── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MySQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=duka_app
DB_USER=root
DB_PASSWORD=your_mysql_password

# ─── Lipana / M-Pesa ───────────────────────────────────────
LIPANA_SECRET_KEY=your_lipana_secret_key_here
LIPANA_BASE_URL=https://api.lipana.dev

# Public URL this server is reachable on (for M-Pesa callbacks)
# Use ngrok / a live URL in production
CALLBACK_URL=https://your-domain.com/payment/callback

# ─── Session / Security ────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string
